{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "templateParts": [
        {
            "name": "header",
            "title": "Header",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Footer",
            "area": "footer"
        }
    ],
    "settings": { 
        "appearanceTools": true,
		"color": {
			"defaultPalette": false,
            "custom": true,
            "defaultGradients": false,
			"palette": [
				{
					"slug": "dark-grey",
					"color": "#666666",
					"name": "Dark grey"
				},
				{
					"slug": "light-grey",
					"color": "#EAECEB",
					"name": "Light Grey"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "og-purple",
					"color": "#4C3343",
					"name": "OG Purple"
				},
				{
					"slug": "og-green",
					"color": "#b4c5a3",
					"name": "OG Green"
				},
				{
					"slug": "mauve",
					"color": "#9E76A8",
					"name": "Muave"
				},
				{
					"slug": "periwinkle",
					"color": "#E7DBEC",
					"name": "Periwinkle"
				},
				{
					"slug": "dark-green",
					"color": "#55645a",
					"name": "Dark Green"
                },
				{
					"slug": "deep-green",
					"color": "#294F40",
					"name": "Deep Green"
				},
				{
					"slug": "dark-sage",
					"color": "#55645A",
					"name": "Dark Sage"
				},
				{
					"slug": "dark-maroon",
					"color": "#94123b",
					"name": "Dark Maroon"
				},
				{
					"slug": "light-pink",
					"color": "#f7cabc",
					"name": "Light Pink"
				},
				{
					"slug": "hot-pink",
					"color": "#ed2074",
					"name": "Hot Pink"
				},
                {
					"slug": "blue",
					"color": "#d2e4ee",
					"name": "Blue"
				},
                {
					"slug": "kajabi-pink",
					"color": "#faf3f5",
					"name": "Kajabi Pink"
				}
			],
			"gradients": [
				{
					"slug": "homepage-hero-gradient",
					"gradient": "linear-gradient(to bottom,var(--wp--preset--color--deep-green) 0%,var(--wp--preset--color--deep-green) 45%,var(--wp--preset--color--white) 45%,var(--wp--preset--color--white) 100%)",
					"name": "homepage Hero Gradient"
				}
			]
		},
		"custom": {
			"fontWeight": {
				"normal": "normal",
				"bold": "bold",
                "italic": "italic",
				"black": 900
			}
		},
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "typography": {
            "fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Raleway",
                            "fontWeight": "400",
							"src": [ "file:./assets/fonts/Raleway-Medium.woff2" ]
						},
						{
							"fontFamily": "Raleway",
                            "fontWeight": "400",
							"fontStyle": "italic",
							"src": [ "file:./assets/fonts/Raleway-Italic.woff2" ]
						},
						{
							"fontFamily": "Raleway",
							"fontWeight": "700",
							"src": [ "file:./assets/fonts/Raleway-Bold.woff2" ]
						}
					],
					"fontFamily": "\"Raleway\", sans-serif",
					"name": "Raleway",
					"slug": "Raleway"
                },
                {
                    "fontFace": [
                        {
                            "fontFamily": "Didot",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "src": [ "file:./assets/fonts/Didot-Regular.woff2" ]
                        },
                        {
                            "fontFamily": "Didot",
                            "fontWeight": "400",
                            "fontStyle": "italic",
                            "src": [ "file:./assets/fonts/Didot-Italic.woff2" ]
                        },
                        {
                            "fontFamily": "Didot",
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "src": [ "file:./assets/fonts/Didot-Bold.woff2" ]
                        }
                    ],
                    "fontFamily": "\"Didot\", serif",
                    "name": "Didot",
                    "slug": "Didot"
                }
            ],
            "fontSizes": [
                { "slug": "small", "size": "0.65rem", "name": "Small" },
                { "slug": "medium", "size": "0.9rem", "name": "Medium" },
                { "slug": "large", "size": "clamp(1rem, 2.5vw, 1.5rem)", "name": "Large" },
                { "slug": "x-large", "size": "clamp(1.5rem, 4vw, 1.8rem)", "name": "Extra Large" }, 
                { "slug": "gigantic", "size": "clamp(2rem, 5vw, 2.5rem)", "name": "Gigantic" } 
            ],
            "lineHeight": true,
            "dropCap": true,
            "fontWeight": true,
            "fontStyle": true,
            "textTransform": true,
            "letterSpacing": true,
            "textDecoration": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true,
            "units": [
                "px", "rem", "vh", "vw", "%"
            ],
            "spacingSizes": [
				{
					"size": "clamp(1.5rem, 5vw, 2rem)",
					"slug": "1",
					"name": "1"
				},
				{
					"size": "clamp(2rem, 6vw, 3rem)",
					"slug": "2",
					"name": "2"
				},
				{
					"size": "clamp(2.5rem, 8vw, 4.5rem)",
					"slug": "3",
					"name": "3"
				},
				{
					"size": "clamp(3.75rem, 10vw, 7rem)",
					"slug": "4",
					"name": "4"
				},
				{
					"size": "clamp(5rem, 5.25rem + ((1vw - 0.48rem) * 9.096), 8rem)",
					"slug": "5",
					"name": "5"
				},
				{
					"size": "clamp(7rem, 14vw, 11rem)",
					"slug": "6",
					"name": "6"
				}
			]
        },
        "layout": {
            "contentSize": "1200px"
        }
    },
    "styles": {
       "color": {
            "text": "var(--wp--preset--color--dark-grey)",
            "background": "var(--wp--preset--color--white)"
       },
       "elements": {
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--mauve)"
                },
                "typography": {
                    "textDecoration": "none"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--og-purple)"
                    },
                    "typography": {
                        "textDecoration": "underline"
                    }
                }
            },
            "button": {
                "color": {
                  "background": "var(--wp--preset--color--og-purple)",
                  "text": "var(--wp--preset--color--white)"
                },
                "typography": {
                  "fontWeight": "500",
                  "fontSize": "1.2rem"
                },
                ":hover": {
                  "color": {
                    "background": "var(--wp--preset--color--mauve)"
                  },
                  "typography": {
                    "textDecoration": "none"
                  }
                }
              },
            "h1": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--raleway)",
                    "fontSize": "var(--wp--preset--font-size--gigantic)"
                }
            },
            "h2": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--raleway)",
                    "fontSize": "var(--wp--preset--font-size--x-large)"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--large)"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--medium)"
                }
            },
            "h5": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--medium)"
                }
            },
            "h6": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--small)"
                }
            }
       },
       "blocks": {
            "core/button": {
                "border": {
                    "radius": "5px",
                    "width": "2px"
                },
                "spacing": {
                    "padding": {
                        "top": ".75rem",
                        "bottom": ".75rem",
                        "left": "1.50rem",
                        "right": "1.50rem"
                    }
                },
                "variations": {
                    "outline": {
                        "border": {
                            "color": "var(--wp--preset--color--og-purple)",
                            "width": "2px"
                        },
                        "color": {
                            "background": "none",
                            "text": "var(--wp--preset--color--og-purple) !important"
                        }
                    }
                }  
            },
            "core/group": {
                "spacing": {
                    "margin": {
                        "top": "var(--wp--preset--spacing--2)",
                        "bottom": "var(--wp--preset--spacing--2)"
                    }
                }
            },
            "core/separator": {
                "border": {
                    "color": "var(--wp--preset--color--periwinkle)",
                    "width": "3px"
                }
            }
       },
       "typography": {
            "fontFamily": "Raleway",
            "fontSize": "16px",
            "fontStyle": "normal",
            "lineHeight": "inherit",
            "textDecoration": "none",
            "textTransform": "none"
       },
       "spacing": {
            "margin": {
                "top": "0px",
                "bottom": "0px",
                "left": "0px",
                "right": "0px"
            },
            "padding": {
                "top": "0px",
                "bottom": "0px",
                "left": "0px",
                "right": "0px"
            },
            "blockGap": "2rem"
       }
    }
}